{
  "name": "pi-assistant",
  "displayName": "PI Assistant",
  "description": "Embedded PI coding agent chat panel for VSCode",
  "version": "0.1.0",
  "publisher": "pi-config",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pi-assistant",
          "title": "PI Assistant",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pi-assistant": [
        {
          "type": "webview",
          "id": "pi-assistant.chatView",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
